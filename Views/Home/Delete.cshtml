@model CodingTest.Models.Employee

@{
	ViewData["Title"] = "Delete";
}

<h1>Delete</h1>


<div>
	@{
		if (Context.Request.Query["employeeid"].Count > 0)
		{
			Employee? _employee = CodingTest.Controllers.HomeController.GetEmployee(int.Parse(Context.Request.Query["employeeid"][0]));
			if (_employee == null)
			{
				<h4>Employee ID Not Found</h4>
				<a asp-action="Index">Back to List</a>
			}
			else
			{
				<h3>Are you sure you want to delete this?</h3>
				<h4>Employee ID @_employee.EmployeeId</h4>
				<hr />
				<dl class="row">
					<dt class="col-sm-2">
						@Html.DisplayNameFor(model => model.Name)
					</dt>
					<dd class="col-sm-10">
						@_employee.Name
					</dd>
					<dt class="col-sm-2">
						@Html.DisplayNameFor(model => model.Address)
					</dt>
					<dd class="col-sm-10">
						@_employee.Address
					</dd>
				</dl>
				<form asp-action="Delete">
					<input type="hidden" asp-for="EmployeeId" value="@_employee.EmployeeId"/>
					<input type="submit" value="Delete" class="btn btn-danger" /> |
					<a asp-action="Index">Back to List</a>
				</form>
			}
		}
		else
		{
			<h4>Please provide a query</h4>
			<a asp-action="Index">Back to List</a>
		}


	}
</div>
